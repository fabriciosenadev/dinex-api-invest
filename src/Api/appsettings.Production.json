{
  "AppSettings": {
    "JwtSecret": "",
    "PasswordPepper": "",
    "SmtpHost": "",
    "SmtpPort": 0,
    "SmtpUseSsl": true,
    "MailboxAddress": "",
    "MailboxPassword": "",
    "MailboxName": "",
    "MailTemplateFolder": "Templates"
  },
  "Database": {
    "Provider": "postgres"
  },
  "ConnectionStrings": {
    "DinExPostgres": "Host=localhost;Port=5432;Database=dinex;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{TraceId}] [{UserId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/production/dinex-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 60,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{TraceId}] [{UserId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
